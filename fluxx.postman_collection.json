    {
      "name": "PubSub / SSE",
      "item": [
        {
          "name": "Subscribe to Flag Events (SSE)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{projectId}}",
                "description": "Project ID — only events for this project are streamed"
              },
              {
                "key": "Accept",
                "value": "text/event-stream"
              },
              {
                "key": "Cache-Control",
                "value": "no-cache"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/pubsub/subscribe",
              "host": ["{{baseUrl}}"],
              "path": ["api", "pubsub", "subscribe"]
            },
            "description": "Opens a persistent SSE connection. The server pushes 'flag-event' events whenever a flag or strategy changes for the given project.\n\nEvent shape:\n{\n  \"projectId\": \"...\",\n  \"flagId\": \"...\",\n  \"eventType\": \"FLAG_CREATED | FLAG_ENABLED | FLAG_DISABLED | FLAG_ARCHIVED | STRATEGY_ADDED | STRATEGY_UPDATED | STRATEGY_REMOVED\",\n  \"afterState\": \"{ ...serialized flag or strategy }\",\n  \"createdAt\": \"2026-05-15T10:00:00\"\n}\n\nNote: Postman does not render SSE streams natively. Use curl or a browser EventSource for live testing:\n  curl -N -H 'Authorization: <projectId>' http://localhost:8080/api/pubsub/subscribe"
          }
        }
      ]
    }
  ]
